# Caddyfile — reverse proxy for CineTrace production
#
# Cloudflare handles SSL/TLS at the edge (orange-cloud proxied DNS).
# Caddy listens on plain HTTP — Cloudflare connects to the origin on port 80.
# Set Cloudflare SSL/TLS mode to "Flexible" in the Cloudflare dashboard.

# ── Main site (Next.js frontend) ─────────────────────────────────────────────
http://cinetrace.in, http://www.cinetrace.in {
    reverse_proxy localhost:3000
}

# ── API subdomain (FastAPI backend) ──────────────────────────────────────────
http://api.cinetrace.in {
    reverse_proxy localhost:8000
}
