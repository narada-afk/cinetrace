# Copy this file to .env and fill in values before running docker compose.
# .env is gitignored — never commit real credentials.

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL credentials (used by the postgres container)
POSTGRES_USER=cinescope
POSTGRES_PASSWORD=                        # generate a strong password
POSTGRES_DB=cinescope

# Full connection URL (used by the FastAPI backend)
# Format: postgresql://<user>:<password>@postgres:5432/<db>
DATABASE_URL=postgresql://cinescope:<password>@postgres:5432/cinescope

# ── Frontend URLs ─────────────────────────────────────────────────────────────
# Public API URL — what the BROWSER uses to reach the backend
# In production: https://api.cinescope.in  (or your actual domain)
NEXT_PUBLIC_API_URL=https://api.cinescope.in

# ── Analytics (baked into the Next.js bundle at build time) ──────────────────
NEXT_PUBLIC_GA_ID=G-9C1FGNHFNH
NEXT_PUBLIC_CLARITY_ID=wd4a9k755e

# PostHog — leave blank to disable
NEXT_PUBLIC_POSTHOG_KEY=

# ── Cache ─────────────────────────────────────────────────────────────────────
# Handled internally by docker-compose (redis://redis:6379/0) — leave blank
REDIS_URL=

# ── Graph ─────────────────────────────────────────────────────────────────────
# Bump this after ingesting new data to trigger in-memory graph rebuild
GRAPH_VERSION=1

# ── Sentry error tracking ─────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=          # only needed for source map uploads

# ── Security ──────────────────────────────────────────────────────────────────
# Secret key for POST /admin/rebuild-graph — generate a random string
ADMIN_API_KEY=
